---
interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" sizes="any" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<header class="site-header">
			<a class="brand" href="/" aria-label="Lior Abitbol home">Lior Abitbol</a>
			<nav aria-label="Primary navigation">
				<a href="/#projects">Projects</a>
				<a href="/resume">Resume</a>
				<a href="/blog">Blog</a>
				<a href="mailto:lior@liorabitbol.com">Contact</a>
			</nav>
		</header>
		<main>
			<slot />
		</main>
		<footer class="site-footer">
			<span>&copy; {new Date().getFullYear()} Lior Abitbol</span>
			<div class="footer-links">
				<a href="mailto:lior@liorabitbol.com">Email</a>
				<a href="https://github.com/LiorAbitbol/" target="_blank" rel="noreferrer">GitHub</a>
				<a href="https://www.linkedin.com/in/liorabitbol/" target="_blank" rel="noreferrer">
					LinkedIn
				</a>
			</div>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		color-scheme: light;
		--ink: #151514;
		--muted: #5f625c;
		--paper: #fbfaf5;
		--surface: #ffffff;
		--line: #dedbd1;
		--accent: #0f766e;
		--accent-dark: #124f4b;
		--clay: #9a5b43;
		--gold: #b7791f;
		--shadow: 0 20px 60px rgba(35, 34, 30, 0.12);
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
			sans-serif;
	}

	* {
		box-sizing: border-box;
	}

	html {
		background: var(--paper);
		color: var(--ink);
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		min-width: 320px;
		font-size: 16px;
		line-height: 1.6;
	}

	a {
		color: inherit;
		text-decoration-color: color-mix(in srgb, currentColor 35%, transparent);
		text-underline-offset: 0.22em;
	}

	a:hover {
		color: var(--accent-dark);
	}

	p {
		margin: 0;
	}

	.site-header,
	.site-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		width: min(1120px, calc(100% - 2rem));
		margin: 0 auto;
	}

	.site-header {
		padding: 1.15rem 0;
	}

	.brand {
		font-weight: 760;
		text-decoration: none;
		white-space: nowrap;
	}

	nav {
		display: flex;
		align-items: center;
		gap: clamp(0.8rem, 2vw, 1.45rem);
		color: var(--muted);
		font-size: 0.95rem;
	}

	nav a {
		text-decoration: none;
	}

	.site-footer {
		border-top: 1px solid var(--line);
		color: var(--muted);
		font-size: 0.95rem;
		margin-top: 4rem;
		padding: 1.5rem 0 2rem;
	}

	.footer-links {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
	}

	.page-section {
		width: min(1120px, calc(100% - 2rem));
		margin: 0 auto;
		padding: clamp(3rem, 7vw, 5.5rem) 0;
	}

		.section-kicker {
			display: block;
			margin-bottom: 0.9rem;
			color: var(--accent-dark);
			font-size: 0.88rem;
			font-weight: 850;
			letter-spacing: 0.08em;
			text-transform: uppercase;
		}

	.section-heading {
		max-width: 760px;
		margin: 0.5rem 0 1.15rem;
		font-size: clamp(2rem, 4vw, 3.35rem);
		line-height: 1.05;
	}

	.section-copy {
		max-width: 720px;
		color: var(--muted);
		font-size: clamp(1.05rem, 1.5vw, 1.2rem);
	}

	.button-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 2rem;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.8rem;
		border: 1px solid var(--ink);
		border-radius: 6px;
		padding: 0.65rem 1rem;
		background: var(--ink);
		color: var(--paper);
		font-weight: 720;
		text-decoration: none;
	}

	.button.secondary {
		background: transparent;
		color: var(--ink);
	}

	.button:hover {
		background: var(--accent-dark);
		border-color: var(--accent-dark);
		color: var(--paper);
	}

	@media (max-width: 700px) {
		.site-header,
		.site-footer {
			align-items: flex-start;
			flex-direction: column;
		}

		nav {
			flex-wrap: wrap;
		}
	}
</style>
