---
import BaseLayout from "../layouts/BaseLayout.astro";

interface Props {
	name: string;
	label: string;
	status: string;
	summary: string;
}

const { name, label, status, summary } = Astro.props;
---

<BaseLayout title={`${name} | Lior Abitbol`} description={`${name}: ${summary}`}>
	<article class="project-page">
		<header class="project-hero">
			<a class="back-link" href="/#projects">← Back to projects</a>
			<p class="section-kicker">{label}</p>
			<div class="hero-row">
				<div>
					<h1>{name}</h1>
					<p>{summary}</p>
				</div>
				<span class="status">{status}</span>
			</div>
		</header>

		<slot />
	</article>
</BaseLayout>

<style is:global>
	.project-page {
		width: min(980px, calc(100% - 2rem));
		margin: 0 auto;
		padding: clamp(3rem, 7vw, 5.5rem) 0 0;
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		margin-bottom: 2rem;
		color: var(--accent-dark);
		font-size: 0.95rem;
		font-weight: 720;
		text-decoration: none;
	}

	.back-link:hover {
		color: var(--clay);
	}

	.project-hero {
		padding-bottom: clamp(2.5rem, 6vw, 4.5rem);
	}

	.hero-row {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 2rem;
		align-items: start;
	}

	.project-page h1 {
		margin: 0.45rem 0 1rem;
		font-size: clamp(3.2rem, 8vw, 6.5rem);
		line-height: 0.94;
	}

	.project-hero p:last-child {
		max-width: 760px;
		color: var(--muted);
		font-size: clamp(1.12rem, 2vw, 1.32rem);
	}

	.status {
		border: 1px solid var(--line);
		border-radius: 999px;
		background: var(--surface);
		color: var(--accent-dark);
		font-size: 0.82rem;
		font-weight: 780;
		padding: 0.35rem 0.7rem;
		white-space: nowrap;
	}

	.project-section {
		border-top: 1px solid var(--line);
		padding: clamp(2rem, 5vw, 3.5rem) 0;
	}

	.project-section h2 {
		max-width: 850px;
		margin: 0;
		font-size: clamp(1.7rem, 3.5vw, 2.7rem);
		line-height: 1.1;
	}

	.section-text,
	.detail-list li {
		color: var(--muted);
	}

	.section-text {
		max-width: 760px;
		font-size: 1.08rem;
	}

	.section-stack {
		display: grid;
		gap: 0.85rem;
		max-width: 760px;
		margin-top: 1rem;
		color: var(--muted);
		font-size: 1.08rem;
	}

	.section-note {
		margin-top: 1rem;
	}

	.detail-list,
	.tech-list {
		display: grid;
		gap: 0.75rem;
		margin: 0;
		padding-left: 1.1rem;
	}

	.detail-list {
		max-width: 760px;
	}

	.narrative-list {
		display: grid;
		gap: 0.85rem;
		max-width: 820px;
		margin: 0;
		padding-left: 1.15rem;
		color: var(--muted);
		font-size: 1.08rem;
	}

	.narrative-list strong {
		color: var(--ink);
		font-weight: 760;
	}

	.section-text + .detail-list {
		margin-top: 1rem;
	}

	.project-section h2 + .narrative-list {
		margin-top: 1.25rem;
	}

	.capability-list {
		display: grid;
		gap: 1rem;
		max-width: 820px;
	}

	.capability-list article {
		border: 1px solid var(--line);
		border-radius: 8px;
		background: var(--surface);
		padding: 1rem;
	}

	.capability-list h3 {
		margin: 0 0 0.35rem;
		font-size: 1.08rem;
		line-height: 1.25;
	}

	.capability-list p {
		color: var(--muted);
	}

	.tech-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem;
		padding-left: 0;
		list-style: none;
	}

	.tech-list li {
		border: 1px solid var(--line);
		border-radius: 6px;
		background: var(--surface);
		color: var(--muted);
		padding: 0.35rem 0.7rem;
	}

	.project-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin: 0.75rem 0 0;
		padding-left: 0;
		list-style: none;
	}

	.project-links a {
		display: inline-flex;
		border: 1px solid var(--ink);
		border-radius: 6px;
		padding: 0.55rem 0.8rem;
		font-weight: 720;
		text-decoration: none;
	}

	.project-links a:hover {
		background: var(--accent-dark);
		border-color: var(--accent-dark);
		color: var(--paper);
	}

	@media (max-width: 760px) {
		.hero-row {
			grid-template-columns: 1fr;
		}

		.status {
			width: fit-content;
		}
	}
</style>
