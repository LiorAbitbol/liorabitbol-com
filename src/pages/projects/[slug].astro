---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { projects } from "../../data/projects";

export function getStaticPaths() {
	return projects.map((project) => ({
		params: { slug: project.slug },
		props: { project },
	}));
}

const { project } = Astro.props;
---

<BaseLayout
	title={`${project.name} | Lior Abitbol`}
	description={`${project.name}: ${project.summary}`}
>
	<article class="project-page">
			<header class="project-hero">
				<a class="back-link" href="/#projects">← Back to projects</a>
			<p class="section-kicker">{project.label}</p>
			<div class="hero-row">
				<div>
					<h1>{project.name}</h1>
					<p>{project.summary}</p>
				</div>
				<span class="status">{project.status}</span>
			</div>
		</header>

			<section class="project-section">
				<p class="section-kicker">What it is</p>
				<h2>{project.overview}</h2>
				{"overviewDetails" in project && project.overviewDetails && (
					<div class="section-stack">
						{project.overviewDetails.map((detail) => <p>{detail}</p>)}
					</div>
				)}
			</section>

			<section class="project-section">
				<p class="section-kicker">Problem</p>
				<p class="section-text">{project.problem}</p>
				{"problemDetails" in project && project.problemDetails && (
					<div class="section-stack">
						{project.problemDetails.map((detail) => <p>{detail}</p>)}
					</div>
				)}
			</section>

			{
				"approach" in project && project.approach && (
					<section class="project-section">
						<p class="section-kicker">Approach</p>
						<p class="section-text">{project.approach}</p>
						{"approachPoints" in project && project.approachPoints && (
							<ul class="detail-list">
								{project.approachPoints.map((point) => <li>{point}</li>)}
							</ul>
						)}
						{"approachNote" in project && project.approachNote && (
							<p class="section-text section-note">{project.approachNote}</p>
						)}
					</section>
				)
			}

			<section class="project-section">
				<p class="section-kicker">{"keyCapabilities" in project ? "Key Capabilities" : "Features / Notes"}</p>
				{
					"keyCapabilities" in project && project.keyCapabilities ? (
						<div class="capability-list">
							{project.keyCapabilities.map((capability) => (
								<article>
									<h3>{capability.title}</h3>
									<p>{capability.description}</p>
								</article>
							))}
						</div>
					) : (
						<ul class="detail-list">
							{project.details.map((detail) => <li>{detail}</li>)}
						</ul>
					)
				}
			</section>

			{
				"currentState" in project && project.currentState && (
					<section class="project-section">
						<p class="section-kicker">Current State</p>
						<ul class="detail-list">
							{project.currentState.map((state) => <li>{state}</li>)}
						</ul>
					</section>
				)
			}

			{
				"whyItMatters" in project && project.whyItMatters && (
					<section class="project-section">
						<p class="section-kicker">Why it matters</p>
						<div class="section-stack">
							{project.whyItMatters.map((item) => <p>{item}</p>)}
						</div>
					</section>
				)
			}

			<section class="project-section tech-section">
				<p class="section-kicker">Technology</p>
			<ul class="tech-list">
				{project.technologies.map((technology) => <li>{technology}</li>)}
			</ul>
		</section>

		{
			"links" in project && project.links && (
				<section class="project-section link-section">
					<p class="section-kicker">Links</p>
					<ul class="project-links">
						{project.links.map((link) => (
							<li>
								<a href={link.href} target="_blank" rel="noreferrer">
									{link.label}
								</a>
							</li>
						))}
					</ul>
				</section>
			)
		}
	</article>
</BaseLayout>

<style>
	.project-page {
		width: min(980px, calc(100% - 2rem));
		margin: 0 auto;
		padding: clamp(3rem, 7vw, 5.5rem) 0 0;
	}

		.back-link {
			display: inline-flex;
			align-items: center;
			margin-bottom: 2rem;
			color: var(--accent-dark);
			font-size: 0.95rem;
			font-weight: 720;
			text-decoration: none;
		}

		.back-link:hover {
			color: var(--clay);
		}

	.project-hero {
		padding-bottom: clamp(2.5rem, 6vw, 4.5rem);
	}

	.hero-row {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 2rem;
		align-items: start;
	}

	h1 {
		margin: 0.45rem 0 1rem;
		font-size: clamp(3.2rem, 8vw, 6.5rem);
		line-height: 0.94;
	}

	.project-hero p:last-child {
		max-width: 760px;
		color: var(--muted);
		font-size: clamp(1.12rem, 2vw, 1.32rem);
	}

	.status {
		border: 1px solid var(--line);
		border-radius: 999px;
		background: var(--surface);
		color: var(--accent-dark);
		font-size: 0.82rem;
		font-weight: 780;
		padding: 0.35rem 0.7rem;
		white-space: nowrap;
	}

	.project-section {
		border-top: 1px solid var(--line);
		padding: clamp(2rem, 5vw, 3.5rem) 0;
	}

			.project-section h2 {
				max-width: 850px;
				margin: 0;
			font-size: clamp(1.7rem, 3.5vw, 2.7rem);
		line-height: 1.1;
	}

	.section-text,
	.detail-list li {
		color: var(--muted);
	}

		.section-text {
			max-width: 760px;
			font-size: 1.08rem;
		}

		.section-stack {
			display: grid;
			gap: 0.85rem;
			max-width: 760px;
			margin-top: 1rem;
			color: var(--muted);
			font-size: 1.08rem;
		}

		.section-note {
			margin-top: 1rem;
		}

		.detail-list,
		.tech-list {
		display: grid;
		gap: 0.75rem;
		margin: 0;
			padding-left: 1.1rem;
		}

		.detail-list {
			max-width: 760px;
		}

		.section-text + .detail-list {
			margin-top: 1rem;
		}

		.capability-list {
			display: grid;
			gap: 1rem;
			max-width: 820px;
		}

		.capability-list article {
			border: 1px solid var(--line);
			border-radius: 8px;
			background: var(--surface);
			padding: 1rem;
		}

		.capability-list h3 {
			margin: 0 0 0.35rem;
			font-size: 1.08rem;
			line-height: 1.25;
		}

		.capability-list p {
			color: var(--muted);
		}

	.tech-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem;
		padding-left: 0;
		list-style: none;
	}

	.tech-list li {
		border: 1px solid var(--line);
		border-radius: 6px;
		background: var(--surface);
		color: var(--muted);
		padding: 0.35rem 0.7rem;
	}

	.project-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin: 0.75rem 0 0;
		padding-left: 0;
		list-style: none;
	}

	.project-links a {
		display: inline-flex;
		border: 1px solid var(--ink);
		border-radius: 6px;
		padding: 0.55rem 0.8rem;
		font-weight: 720;
		text-decoration: none;
	}

	.project-links a:hover {
		background: var(--accent-dark);
		border-color: var(--accent-dark);
		color: var(--paper);
	}

	@media (max-width: 760px) {
		.hero-row {
			grid-template-columns: 1fr;
		}

		.status {
			width: fit-content;
		}
	}
</style>
